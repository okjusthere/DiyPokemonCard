# ═══ DIY Pokemon Card Maker — Environment Variables ═══

# Server
PORT=3000

# Azure OpenAI (required for AI card generation)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Email (optional — for sending Pokemon cards to email)
# For Gmail, use an "App Password" from https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
