# ═══ DIY Poke Card Maker — Environment Variables ═══

# Server
PORT=3000
TRUST_PROXY=1
NODE_ENV=production

# Base URL (for Stripe redirect — use your custom domain in production)
BASE_URL=https://www.diypokecard.com

# Azure OpenAI (required for AI card generation)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_IMAGE_API_VERSION=2025-04-01-preview
AZURE_IMAGE_MODEL=gpt-image-1
AZURE_GPT_MINI_MODEL=gpt-5-mini
AZURE_GPT_MAIN_MODEL=gpt-4o

# Email (optional — for sending cards to email)
# For Gmail, use an "App Password" from https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Stripe (required for paid card generation)
# Use sk_test_xxx for testing, sk_live_xxx for production
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook endpoint: https://www.diypokecard.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
