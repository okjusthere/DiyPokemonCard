# ═══ DIY Pokemon Card Maker — Environment Variables ═══

# Server
PORT=3000

# Azure OpenAI (required for AI card generation)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Email (optional — for sending Pokemon cards to email)
# For Gmail, use an "App Password" from https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Stripe (required for paid card generation)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL (for Stripe redirect — needed behind reverse proxy)
BASE_URL=https://your-domain.up.railway.app
